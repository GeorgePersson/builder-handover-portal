{
  "name": "handover-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:docling": "set DOCUMENT_CONTEXT_PROVIDER=docling_local&& next dev",
    "dev:unstructured": "set DOCUMENT_CONTEXT_PROVIDER=unstructured&& next dev",
    "build": "next build",
    "demo:generate-100-item-spec": "node scripts/generate-100-item-spec.mjs",
    "cloudflare:dev": "npx.cmd wrangler dev --config cloudflare/handover-pipeline/wrangler.jsonc",
    "cloudflare:deploy": "npx.cmd wrangler deploy --config cloudflare/handover-pipeline/wrangler.jsonc",
    "cloudflare:smoke:d1-dry-run": "node scripts/smoke-cloudflare-d1-dry-run.mjs",
    "cloudflare:smoke:live-guard": "node scripts/smoke-cloudflare-live-guard.mjs",
    "cloudflare:smoke:retry": "node scripts/smoke-cloudflare-retry.mjs",
    "start": "next start",
    "lint": "eslint",
    "supabase:smoke:readiness": "node scripts/smoke-supabase-readiness.mjs",
    "document-context:readiness": "node scripts/check-document-context-readiness.mjs",
    "docling:smoke:local": "node scripts/smoke-docling-local.mjs",
    "spec-extract:fixtures": "node scripts/check-spec-extract-fixtures.mjs",
    "spec-candidates:fixtures": "node scripts/check-spec-candidate-fixtures.mjs",
    "spec-llm:fixtures": "node scripts/check-spec-llm-application-fixtures.mjs",
    "spec-normalizer:fixtures": "node scripts/check-spec-text-normalizer-fixtures.mjs",
    "spec-normalizer:smoke": "node scripts/smoke-spec-text-normalizer.mjs",
    "spec-final-quality:fixtures": "node scripts/check-spec-final-quality-fixtures.mjs",
    "spec-quality-audit:fixtures": "node scripts/check-spec-quality-audit-fixtures.mjs",
    "spec-route:quality-smoke": "node scripts/smoke-spec-route-quality.mjs",
    "spec-extract:smoke": "node scripts/smoke-spec-extract.mjs",
    "spec-extract:llm-smoke": "node scripts/smoke-spec-extract-llm.mjs",
    "ui:audit:static": "node .agents/skills/impeccable/scripts/detect.mjs src/app src/components src/app/globals.css",
    "ui:audit:static:json": "node scripts/run-impeccable-static.mjs",
    "ui:routes": "node scripts/check-ui-routes.mjs",
    "ui:audit": "npm.cmd run ui:audit:static:json && npm.cmd run ui:routes",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
